{
  "name": "Helpline Call Record",
  "module": "Ambulance Service",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "format:CALL-{YYYY}{MM}{DD}-{####}",
  "track_changes": 1,
  "fields": [
    {"fieldname":"helpline_number","label":"Helpline Number",
     "fieldtype":"Select",
     "options":"108\n102\n104\n112\n1033\n100\n181\n1298",
     "reqd":1,"in_list_view":1,"bold":1},
    {"fieldname":"call_datetime","label":"Call Date & Time",
     "fieldtype":"Datetime","reqd":1,"default":"Now"},
    {"fieldname":"call_status","label":"Call Status","fieldtype":"Select",
     "options":"Received\nDispatched\nEn Route\nOn Scene\nTransporting\nCompleted\nCancelled\nMissed",
     "default":"Received","in_list_view":1},
    {"fieldname":"col_break_1","fieldtype":"Column Break"},
    {"fieldname":"triage_priority","label":"Triage Priority",
     "fieldtype":"Select",
     "options":"P1 Critical\nP2 Urgent\nP3 Non-Urgent\nP4 Dead on Arrival",
     "reqd":1,"in_list_view":1},
    {"fieldname":"operator_name","label":"Operator",
     "fieldtype":"Link","options":"Employee"},
    {"fieldname":"assigned_ambulance","label":"Assigned Ambulance",
     "fieldtype":"Link","options":"Ambulance Master"},
    {"fieldname":"sec_caller","label":"Caller Information",
     "fieldtype":"Section Break"},
    {"fieldname":"caller_name","label":"Caller Name","fieldtype":"Data","reqd":1},
    {"fieldname":"caller_phone","label":"Caller Phone","fieldtype":"Data","reqd":1},
    {"fieldname":"relationship","label":"Relationship to Patient",
     "fieldtype":"Select",
     "options":"Self\nRelative\nBystander\nHospital\nPolice"},
    {"fieldname":"sec_patient","label":"Patient Information",
     "fieldtype":"Section Break"},
    {"fieldname":"patient_name","label":"Patient Name","fieldtype":"Data"},
    {"fieldname":"patient_age","label":"Age","fieldtype":"Int"},
    {"fieldname":"patient_gender","label":"Gender","fieldtype":"Select",
     "options":"Male\nFemale\nOther"},
    {"fieldname":"nature_of_emergency","label":"Nature of Emergency",
     "fieldtype":"Select",
     "options":"Cardiac\nTrauma\nAccident\nObstetric\nNeonatal\nRespiratory\nNeurological\nAnimal Bite\nHighway Accident\nWomen Safety\nMental Health\nGeneral","reqd":1},
    {"fieldname":"sec_location","label":"Location","fieldtype":"Section Break"},
    {"fieldname":"pickup_address","label":"Pickup Address",
     "fieldtype":"Small Text","reqd":1},
    {"fieldname":"pickup_latitude","label":"Latitude","fieldtype":"Float"},
    {"fieldname":"pickup_longitude","label":"Longitude","fieldtype":"Float"},
    {"fieldname":"nearest_landmark","label":"Nearest Landmark",
     "fieldtype":"Data"},
    {"fieldname":"state","label":"State","fieldtype":"Link","options":"State"},
    {"fieldname":"district","label":"District","fieldtype":"Data"},
    {"fieldname":"area_type","label":"Area Type","fieldtype":"Select",
     "options":"Urban\nRural\nHighway\nRemote\nWaterway"},
    {"fieldname":"sec_dispatch","label":"Dispatch","fieldtype":"Section Break"},
    {"fieldname":"destination_hospital","label":"Destination Hospital",
     "fieldtype":"Link","options":"Customer"},
    {"fieldname":"dispatch_time","label":"Dispatch Time","fieldtype":"Datetime"},
    {"fieldname":"eta_minutes","label":"ETA (minutes)","fieldtype":"Int"},
    {"fieldname":"sec_flags","label":"Special Flags","fieldtype":"Section Break"},
    {"fieldname":"is_maternity_case","label":"102 Maternity Case",
     "fieldtype":"Check"},
    {"fieldname":"is_neonatal","label":"Neonatal Transfer","fieldtype":"Check"},
    {"fieldname":"is_highway","label":"Highway Incident (1033)",
     "fieldtype":"Check"},
    {"fieldname":"highway_name","label":"Highway / NH No.","fieldtype":"Data",
     "depends_on":"eval:doc.is_highway"},
    {"fieldname":"is_women_safety","label":"Women Safety (181)",
     "fieldtype":"Check"},
    {"fieldname":"shelter_required","label":"Shelter Required",
     "fieldtype":"Check","depends_on":"eval:doc.is_women_safety"}
  ],
  "permissions": [
    {"role":"Call Centre Agent","read":1,"write":1,"create":1,"submit":0},
    {"role":"Dispatch Officer","read":1,"write":1,"create":1,"submit":1},
    {"role":"CAD Operator","read":1,"write":1,"create":1,"submit":0},
    {"role":"Paramedic","read":1,"write":0},
    {"role":"System Manager","read":1,"write":1,"create":1,"delete":1,"submit":1}
  ],
  "title_field": "name",
  "naming_rule": "Expression (old style)"
}
