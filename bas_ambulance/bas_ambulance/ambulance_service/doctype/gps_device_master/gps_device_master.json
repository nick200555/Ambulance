{
  "name": "GPS Device Master",
  "module": "BAS Ambulance Service",
  "doctype": "DocType",
  "fields": [
    {"fieldname":"device_id","label":"Device ID","fieldtype":"Data","reqd":1},
    {"fieldname":"imei_number","label":"IMEI Number","fieldtype":"Data","reqd":1},
    {"fieldname":"device_make_model","label":"Make / Model","fieldtype":"Data"},
    {"fieldname":"sim_number","label":"SIM Number","fieldtype":"Data"},
    {"fieldname":"telecom_operator","label":"Telecom Operator","fieldtype":"Select",
     "options":"Airtel\nBSNL\nJio\nVi\nOther"},
    {"fieldname":"data_plan_expiry","label":"Data Plan Expiry","fieldtype":"Date"},
    {"fieldname":"assigned_ambulance","label":"Assigned Ambulance",
