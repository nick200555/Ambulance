{
  "name": "Telemedicine Consultation",
  "module": "BAS Ambulance Service",
  "doctype": "DocType",
  "is_submittable": 1,
  "autoname": "format:TELE-{YYYY}-{#####}",
  "fields": [
    {"fieldname":"helpline_call","label":"Helpline Call",
     "fieldtype":"Link","options":"Helpline Call Record"},
    {"fieldname":"consultation_datetime","label":"Consultation Date & Time",
     "fieldtype":"Datetime","reqd":1,"default":"Now"},
    {"fieldname":"consulting_doctor","label":"Consulting Doctor",
     "fieldtype":"Link","options":"Crew Member","reqd":1},
    {"fieldname":"speciality","label":"Speciality","fieldtype":"Select",
     "options":"General\nCardiology\nGynaecology\nPaediatrics\nPsychiatry\nOrthopaedics\nDermatology\nOther"},
    {"fieldname":"duration_minutes","label":"Duration (min)","fieldtype":"Int"},
    {"fieldname":"consultation_status","label":"Status","fieldtype":"Select",
     "options":"In Progress\nCompleted\nReferred\nAbandoned",
     "default":"In Progress","in_list_view":1},
    {"fieldname":"sec_patient","label":"Patient","fieldtype":"Section Break"},
    {"fieldname":"patient_name","label":"Patient Name","fieldtype":"Data"},
    {"fieldname":"patient_age","label":"Age","fieldtype":"Int"},
    {"fieldname":"patient_gender","label":"Gender","fieldtype":"Select",
     "options":"Male\nFemale\nOther"},
    {"fieldname":"chief_complaint","label":"Chief Complaint",
     "fieldtype":"Small Text","reqd":1},
    {"fieldname":"sec_advice","label":"Advice & Prescription","fieldtype":"Section Break"},
    {"fieldname":"advice_given","label":"Advice Given","fieldtype":"Text Editor"},
    {"fieldname":"prescription","label":"Prescription","fieldtype":"Text Editor"},
    {"fieldname":"referral_required","label":"Referral Required","fieldtype":"Check"},
    {"fieldname":"referred_to_hospital","label":"Referred to Hospital",
     "fieldtype":"Link","options":"Customer",
     "depends_on":"eval:doc.referral_required"},
    {"fieldname":"ambulance_dispatched","label":"Ambulance Dispatched",
     "fieldtype":"Check"},
    {"fieldname":"followup_required","label":"Follow-up Required","fieldtype":"Check"},
    {"fieldname":"followup_date","label":"Follow-up Date","fieldtype":"Date",
     "depends_on":"eval:doc.followup_required"}
  ],
  "permissions": [
    {"role":"Call Centre Agent","read":1,"write":1,"create":1},
    {"role":"System Manager","read":1,"write":1,"create":1,"delete":1,"submit":1}
  ]
}
